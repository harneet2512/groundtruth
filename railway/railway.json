{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "railway/Dockerfile"
  },
  "deploy": {
    "startCommand": "/app/railway/entrypoint.sh",
    "restartPolicyType": "NEVER",
    "numReplicas": 1,
    "sleepApplication": false
  }
}
